    lossnode/.style={rectangle, draw=purple!55, fill=purple!7, rounded corners=4pt, minimum width=1.6cm, minimum height=0.7cm, align=center, font=\footnotesize, line width=0.7pt},
    cosnode/.style={rectangle, draw=orange!50, fill=orange!6, rounded corners=3pt, minimum width=1.5cm, minimum height=0.5cm, align=center, font=\scriptsize, line width=0.5pt},
    grponode/.style={rectangle, draw=purple!45, fill=purple!6, rounded corners=3pt, minimum width=1.3cm, minimum height=0.5cm, align=center, font=\scriptsize, line width=0.5pt},
    combnode/.style={rectangle, draw=violet!50, fill=violet!6, rounded corners=4pt, minimum width=2.0cm, minimum height=0.6cm, align=center, font=\footnotesize, line width=0.7pt},
    flowarr/.style={->, thick, >=stealth, color=gray!60!black},
    emaarr/.style={->, line width=1.6pt, >=stealth, color=blue!45, dashed},
    gradarr/.style={->, thick, >=stealth, color=purple!55},
    steplbl/.style={font=\fontsize{5.5}{6.5}\selectfont, color=gray!50!black, fill=white, inner sep=1pt, rounded corners=1pt}
]
    % ============================================================
    % ROW 1 (top): Student -> Trajectory -> Outcome -> Priv. Info -> Teacher -> Logprobs
    % ============================================================

    % Step 1: Student
    \node[stubox] (stu) {\textbf{Student} $\theta_S$};
    \node[steplbl] at ([yshift=0.55cm]stu.north) {\textbf{1} rollout};

    % Step 2: Trajectory
    \node[turnnode, right=1.0cm of stu] (tc1) {Tool Call};
    \node[turnnode, right=0.06cm of tc1] (tr1) {Tool Resp};
    \node[turnnode, right=0.06cm of tr1] (ta1) {Answer};
    \node[draw=gray!35, rounded corners=2.5pt, inner sep=3pt, fit=(tc1)(tr1)(ta1), line width=0.35pt] (trajbox) {};
    \node[font=\scriptsize, color=gray!55!black] at ([yshift=0.35cm]tr1.north) {Trajectory $\tau$};
    \draw[flowarr] (stu.east) -- node[steplbl, above] {generate} (trajbox.west);

    % Step 3: Outcome classification (split)
    \node[outcbox=green!60!black, right=0.8cm of trajbox, yshift=0.65cm] (corr) {\textcolor{green!50!black}{\ding{51}}\;\textbf{Correct}};
    \node[outcbox=orange, right=0.8cm of trajbox, yshift=-0.65cm] (incorr) {\textcolor{red!55!black}{\ding{55}}\;\textbf{Incorrect}};
    \node[steplbl] at ([yshift=0.55cm]corr.north) {\textbf{2} classify};

    \draw[flowarr, color=green!50!black] (trajbox.east) |- (corr.west);
    \draw[flowarr, color=orange!55!black] (trajbox.east) |- (incorr.west);

    % Step 4: Privileged information injection (stars + labels)
    \node[privstar=green!60!black, right=0.4cm of corr] (starc) {};
    \node[privlabel=green!60!black, right=0.15cm of starc] (plblc) {``sound reasoning''};

    \node[privstar=orange, right=0.4cm of incorr] (stari) {};
    \node[privlabel=orange, right=0.15cm of stari] (plbli) {``revisit diagnosis''};

    \node[steplbl] at ([yshift=0.55cm]plblc.north) {\textbf{3} privileged hints};

    \draw[flowarr, color=green!50!black] (corr.east) -- (starc.west);
    \draw[flowarr, color=orange!55!black] (incorr.east) -- (stari.west);

    % Step 5: Teacher
    \node[tchbox, right=0.5cm of plblc, yshift=-0.65cm] (tch) {\textbf{Teacher} $\theta_T$};
    \node[steplbl] at ([yshift=0.55cm]tch.north) {\textbf{4} re-score};

    \draw[flowarr, color=green!50!black] (plblc.east) -| ([xshift=0.15cm]tch.north west);
    \draw[flowarr, color=orange!55!black] (plbli.east) -| ([xshift=0.15cm]tch.south west);

    % Step 6: Teacher logprobs output
    \node[font=\scriptsize, color=red!50!black, right=0.7cm of tch] (logp) {$\log \pi_{\theta_T}(a|s)$};
    \draw[flowarr, color=red!45] (tch.east) -- node[steplbl, above] {logprobs} (logp.west);

    % ============================================================
    % ROW 2 (bottom): Loss components -> Combined -> Student update
    % ============================================================

    % KL Loss (below teacher)
    \node[lossnode, below=1.8cm of tch] (klloss) {$\mathcal{L}_{\text{KL}}$\\[-2pt]\fontsize{5.5}{6.5}\selectfont Turn-Level Trunc.};
    \draw[flowarr, color=red!45] (logp.south) -- ++(0,-0.5) -| (klloss.north);

    % Student logprobs feed into KL too
    \node[font=\scriptsize, color=blue!50!black, below=1.8cm of trajbox] (stulogp) {$\log \pi_{\theta_S}(a|s)$};
    \draw[flowarr, color=blue!40] ([yshift=-0.15cm]stu.south) |- (stulogp.west);
    \draw[flowarr, color=blue!40] (stulogp.east) -- (klloss.west);

    % Cosine reward (below trajectory)
    \node[cosnode, below=1.8cm of corr] (cosrew) {$R_{\text{cos}}$\;Cosine};
    \node[steplbl] at ([yshift=-0.45cm]cosrew.south) {length control};

    % GRPO
    \node[grponode, left=0.5cm of cosrew] (grpo) {GRPO};
    \draw[flowarr, color=orange!50] (cosrew.west) -- (grpo.east);

    % GRPO loss
    \node[lossnode, below=0.7cm of grpo] (grpoloss) {$\mathcal{L}_{\text{GRPO}}$\\[-2pt]\fontsize{5.5}{6.5}\selectfont Policy Grad.};
    \draw[flowarr, color=purple!45] (grpo.south) -- (grpoloss.north);

    % Combined loss
    \node[combnode, below=0.7cm of klloss] (comb) {$\mathcal{L} = \mathcal{L}_{\text{GRPO}} + \lambda \mathcal{L}_{\text{KL}}$};
    \draw[flowarr, color=purple!45] (klloss.south) -- (comb.north);
    \draw[flowarr, color=purple!45] (grpoloss.east) -- (comb.west);

    % Gradient to student
    \draw[gradarr, line width=1.2pt, rounded corners=4pt] (comb.west) -- ++(-1.0, 0) |- node[steplbl, pos=0.25, above] {$\nabla_{\theta_S}\mathcal{L}$} ([yshift=-0.5cm]stu.south) -- (stu.south);
    \node[steplbl] at ([yshift=-0.85cm]stu.south) {\textbf{6} update};

    % ============================================================
    % EMA feedback loop (prominent dashed blue)
    % ============================================================
    \coordinate (ema_bl) at ([yshift=-3.8cm, xshift=-0.3cm]stu.south);
    \coordinate (ema_br) at (tch.south |- ema_bl);
    \draw[emaarr, rounded corners=5pt] ([xshift=0.3cm, yshift=-0.5cm]stu.south) -- ([xshift=0.3cm]stu.south |- ema_bl) -- node[below, font=\scriptsize, color=blue!50!black] {\textbf{EMA:}\;$\theta_T \leftarrow \alpha\,\theta_T + (1{-}\alpha)\,\theta_S$\quad$(\alpha{=}0.995)$} (ema_br) -- ([yshift=-0.15cm]tch.south);
    \node[steplbl, color=blue!50!black] at ([yshift=-0.3cm]ema_bl |- ema_br) {\textbf{5} co-evolution};

\end{tikzpicture}%
}%
\caption{Overview of TT-OPD. The student $\theta_S$ generates multi-turn trajectories, which are classified by outcome. Outcome-privileged information (injected into the teacher's context only, marked with~$\bigstar$) makes the teacher's logprobs outcome-aware. The turn-level KL loss provides dense per-turn supervision across all conversation turns. The teacher co-evolves via EMA ($\alpha{=}0.995$), and cosine length-controlled reward feeds into GRPO to prevent response explosion.}
\label{fig:ttopd}
\end{figure}

A persistent failure mode in agentic RL is \emph{response explosion}: the model learns to generate increasingly long single-turn responses that bypass multi-turn tool use, eventually saturating the context window (12,288 tokens). Standard GRPO provides no mechanism to prevent this degeneration. We propose \emph{Turn-Level Truncated On-Policy Distillation} (TT-OPD), a teacher-student co-evolution framework that provides both the learning signal for accuracy improvement and the structural regularization to maintain multi-turn behavior.

\paragraph{Core Method: TT-OPD.}
We maintain a teacher model $\theta_T$ that co-evolves with the student $\theta_S$. The student is trained with a turn-level truncated on-policy distillation loss that regularizes the policy toward the teacher across \emph{all} conversation turns ($\texttt{max\_turn}=0$):
\begin{equation}
    \mathcal{L}_{\text{TT-OPD}} = \lambda_{\text{KL}} \sum_{t=1}^{T} \frac{1}{|a_t|} \sum_{k=1}^{|a_t|} D_{\text{KL}}\!\left(\pi_{\theta_S}(\cdot \mid s_t, a_t^{<k}) \;\|\; \pi_{\theta_T}(\cdot \mid s_t^{+}, a_t^{<k})\right)
\end{equation}
where $s_t^{+}$ denotes the state augmented with outcome-privileged information, $|a_t|$ is the number of tokens in action $a_t$, and the outer sum runs over all non-truncated turns ($L_t < L_{\max}$). ``Turn-level'' refers to computing the KL loss across all conversation turns, not just the final answer turn. ``Truncated'' refers to discarding contributions from responses that exceed the context window. Unlike frozen-teacher distillation (which collapses as the student improves beyond the teacher), the co-evolving teacher creates a \emph{moving} regularization target that tracks the student's improving policy---preventing catastrophic divergence while allowing continuous policy improvement.

\paragraph{KL Direction.}
We use forward KL ($D_{\text{KL}}(\pi_S \| \pi_T)$) rather than reverse KL because the teacher conditions on privileged information that the student cannot access. Forward KL encourages the student to cover the full support of the teacher's privileged distribution, preventing mode collapse onto a subset of the teacher's behavior. Reverse KL would instead encourage the student to match only the teacher's highest-probability modes, potentially ignoring outcome-dependent corrective signals in low-probability regions.

\paragraph{Outcome-Privileged Teacher Conditioning.}
Standard OPD treats correct and incorrect trajectories identically when computing teacher logprobs---the teacher distribution provides the same regularization target regardless of outcome. We introduce \emph{outcome-privileged teacher conditioning}: during teacher logprob computation, correctness-conditioned privileged information is inserted at the prompt-response boundary, modifying the teacher's probability distribution to be outcome-aware. For correct trajectories, the privileged context reinforces the student's reasoning (``the diagnostic reasoning appears sound, but consider alternative diagnoses''); for incorrect trajectories, it provides corrective guidance (``some aspects need re-examination---revisit the differential diagnosis''). Privileged information can be dynamically generated from templates that include the student's specific answer, providing case-specific rather than generic feedback.

Critically, the privileged tokens are \emph{removed} from the teacher's output logprobs after computation, so the student never sees them directly. Instead, the privileged information influences the teacher's probability distribution, creating a KL target that differentially regularizes correct vs.\ incorrect behavior: the teacher ``knows'' whether the trajectory succeeded, making the turn-level KL loss outcome-aware at every turn. This transforms the TT-OPD loss from a generic regularizer into a form of \emph{outcome-conditioned process supervision}.

\paragraph{Why TT-OPD Enables Agentic Learning.}
The method addresses the core challenge of multi-turn agentic RL: the reward signal is sparse (only at the final turn) and diluted by format compliance, making it difficult for the student to learn \emph{which turns} contributed to success. TT-OPD solves this in two ways: (1) the turn-level KL loss provides dense, per-turn regularization rather than sparse final-turn reward, and (2) outcome-privileged conditioning makes this regularization outcome-aware---correct trajectories are reinforced differently from incorrect ones. This combination explains why TT-OPD achieves +8.5 pp accuracy improvement while standard GRPO (which lacks per-turn supervision) shows no improvement.


\subsection{Training Stability Mechanisms}
\label{sec:stability}

TT-OPD provides the learning signal, but agentic RL also requires mechanisms to prevent training instability. We employ two complementary techniques: EMA scheduling for smooth teacher evolution, and cosine length-controlled reward for response length control.

\paragraph{EMA Teacher Schedule.}
The teacher model $\theta_T$ is updated via exponential moving average:
\begin{equation}
    \theta_T \leftarrow \alpha \cdot \theta_T + (1 - \alpha) \cdot \theta_S, \quad \alpha = 0.995
\end{equation}
updated every 5 training steps. Additionally, a hard copy ($\theta_T \leftarrow \theta_S$) is performed every 30 steps as a fallback to prevent excessive teacher-student drift. The EMA schedule ensures the teacher evolves smoothly---too fast ($\alpha < 0.99$) causes oscillation; too slow ($\alpha > 0.999$) makes the teacher stale. We find $\alpha = 0.995$ provides the optimal balance (Section~\ref{sec:opd_results}).

\paragraph{Cosine Length-Controlled Reward.}
To prevent response explosion at the reward level, we replace the binary accuracy reward with a length-modulated variant inspired by \citet{yeo2025cosine}:
\begin{equation}
    R_{\text{cos}}(c, L) = \begin{cases}
        R_{\text{max}} - \frac{1}{2}(R_{\text{max}} - R_{\text{min}})(1 - \cos(\pi L / L_{\text{max}})) & \text{if correct} \\[4pt]
        -\frac{1}{2}|R_{\text{min}}|(1 - \cos(\pi L / L_{\text{max}})) & \text{if incorrect} \\[4pt]
        R_{\text{penalty}} & \text{if response is truncated at } L_{\text{max}}
    \end{cases}
\label{eq:cosine_reward}
\end{equation}
where $L$ is the response length in tokens, $L_{\text{max}} = 12{,}288$, $R_{\text{max}} = 1.1$, $R_{\text{min}} = 0.7$, and $R_{\text{penalty}} = -0.5$. The third case (truncation penalty) applies only when generation is forcibly stopped at the context limit, not when the model naturally produces a response of exactly $L_{\text{max}}$ tokens. Correct short responses receive high reward ($\sim$1.1), which decays smoothly for longer responses; incorrect long responses receive increasing penalty. Critically, the cosine reward is applied only during training---validation uses standard binary accuracy to ensure unbiased evaluation.

\begin{algorithm}[t]
\caption{Turn-Level Truncated On-Policy Distillation (TT-OPD)}
\label{alg:ttopd}
\begin{algorithmic}[1]
\REQUIRE Base model $\theta_S$, EMA decay $\alpha{=}0.995$, KL weight $\lambda_{\text{KL}}{=}0.01$, max context $L_{\max}{=}12{,}288$, EMA interval $T_{\text{ema}}{=}5$, task distribution $\mathcal{T}$
\ENSURE Trained student $\theta_S$
\STATE Initialize teacher $\theta_T \leftarrow \theta_S$
\FOR{step $t = 1, 2, \ldots$}
    \STATE Sample batch of prompts $\{x_i\}$ from $\mathcal{T}$
    \FOR{each prompt $x_i$}
        \STATE Generate $G$ rollouts via multi-turn interaction with environment
        \STATE Score each rollout with cosine reward $R_{\text{cos}}$ (Eq.~\ref{eq:cosine_reward})
    \ENDFOR
    \STATE Filter: keep only prompts with mixed outcomes \COMMENT{dynamic sampling}
    \STATE Compute group-relative advantages $\hat{A}$ from $R_{\text{cos}}$
    \FOR{each rollout $\tau = (s_1, a_1, \ldots, s_T, a_T)$}
        \STATE Inject outcome-privileged context into teacher prompt
        \STATE Compute teacher logprobs $\pi_{\theta_T}(a_t \mid s_t)$ for all turns $t$
        \STATE Remove privileged tokens from teacher output
    \ENDFOR
    \STATE Compute $\mathcal{L}_{\text{total}} = \mathcal{L}_{\text{GRPO}}(\theta_S;\, R_{\text{cos}}) + \lambda_{\text{KL}} \cdot D_{\text{KL}}(\pi_{\theta_S} \| \pi_{\theta_T})$ \COMMENT{Eq.~\ref{eq:full_objective}}
    \STATE Update $\theta_S$ via gradient descent on $\mathcal{L}_{\text{total}}$
    \IF{$t \bmod T_{\text{ema}} = 0$}
        \STATE $\theta_T \leftarrow \alpha \cdot \theta_T + (1 - \alpha) \cdot \theta_S$ \COMMENT{EMA teacher update}
    \ENDIF
\ENDFOR
\end{algorithmic}
\end{algorithm}

\paragraph{Interaction Between Components.}
The three components---TT-OPD, EMA scheduling, and cosine reward---serve distinct roles: (1) TT-OPD provides the core learning signal (why accuracy improves), (2) EMA scheduling ensures the teacher tracks the student without catastrophic drift (why training doesn't diverge), and (3) the cosine reward prevents response explosion at the reward level (why multi-turn structure is maintained). Ablation results (Section~\ref{sec:opd_results}) confirm that removing any component degrades performance: without privileged conditioning, accuracy plateaus; without EMA, training collapses; without cosine reward, response length explodes.

\paragraph{Full Training Objective.}
The complete training loss combines the GRPO surrogate objective with on-policy distillation:
\begin{equation}
    \mathcal{L}_{\text{total}} = \mathcal{L}_{\text{GRPO}}(\theta_S;\, R_{\text{cos}}) + \lambda_{\text{KL}} \cdot D_\text{KL}\!\left(\pi_{\theta_S} \| \pi_{\theta_T}\right)
    \label{eq:full_objective}
\end{equation}
where $\mathcal{L}_{\text{GRPO}}$ is the clipped surrogate loss with group-relative advantages computed from the cosine length-controlled reward $R_{\text{cos}}$, and the KL term is computed at the turn level across \emph{all} conversation turns in the trajectory (not just the final answer). The teacher $\theta_T$ is updated via EMA ($\alpha_{\text{EMA}} = 0.995$) every 5 training steps, and its logprobs are conditioned on outcome-privileged context that is injected during computation but removed from the output distribution seen by the student.


